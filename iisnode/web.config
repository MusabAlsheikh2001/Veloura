<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <appSettings>
    <add key="NG_ALLOWED_HOSTS" value="veloura-marketing.com,www.veloura-marketing.com,localhost,127.0.0.1" />
  </appSettings>

  <system.webServer>
    <handlers>
      <add name="iisnode" path="server.js" verb="*" modules="iisnode" />
    </handlers>

    <rewrite>
      <rules>
        <rule name="Redirect www to non-www" stopProcessing="true">
          <match url="(.*)" />
          <conditions>
            <add input="{HTTP_HOST}" pattern="^www\.veloura-marketing\.com$" ignoreCase="true" />
          </conditions>
          <action type="Redirect" url="https://veloura-marketing.com/{R:1}" redirectType="Permanent" appendQueryString="true" />
        </rule>

        <rule name="Veloura Angular SSR" stopProcessing="true">
          <match url=".*" />
          <action type="Rewrite" url="server.js" />
        </rule>
      </rules>
    </rewrite>

    <iisnode
      node_env="production"
      watchedFiles="web.config;server.js;server\*.mjs"
      loggingEnabled="false"
      devErrorsEnabled="false" />

    <httpErrors existingResponse="PassThrough" />
  </system.webServer>
</configuration>
